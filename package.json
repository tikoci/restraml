{
  "name": "restraml",
  "description": "RouterOS Schema Tools",
  "private": true,
  "type": "module",
  "scripts": {
    "schema": "echo 'Usage: URLBASE=http://<router>/rest BASICAUTH=admin: bun rest2raml.js [path...]'",
    "schema:version": "echo 'Usage: URLBASE=http://<router>/rest BASICAUTH=admin: bun rest2raml.js --version'",
    "deep-inspect": "bun deep-inspect.ts",
    "deep-inspect:multi-arch": "bun scripts/deep-inspect-multi-arch.ts",
    "deep-inspect:diff": "bun scripts/diff-deep-inspect.ts",
    "validate:raml": "node validraml.cjs",
    "validate:openapi": "bun validate-openapi.ts",
    "validate:app-yaml": "echo 'Usage: bun appyamlvalidate.js <version>'",
    "test": "bun test",
    "test:qemu": "./scripts/test-with-qemu.sh",
    "test:ros-api": "./scripts/test-ros-api.sh",
    "test:benchmark": "./scripts/benchmark-qemu.sh",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bun run lint:bun && bun run lint:workflows",
    "lint:bun": "bunx @biomejs/biome check . && bunx tsc --noEmit",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "lint:workflows": "bun validate-workflows.mjs"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "optionalDependencies": {
    "@tikoci/quickchr": "file:../quickchr"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@biomejs/biome": "^2.0.0",
    "actionlint": "^2.0.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bun-types": "^1.3.11",
    "webapi-parser": "^0.5.0"
  }
}
